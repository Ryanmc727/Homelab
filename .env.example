# ntfy push notifications
NTFY_URL=https://ntfy.yourdomain.com/your-topic
NTFY_USER=your_ntfy_user
NTFY_PASS=your_ntfy_password

# Pi-hole
PIHOLE_PASSWORD=your_pihole_password

# Authentik SSO
AUTHENTIK_PG_PASS=your_postgres_password
AUTHENTIK_SECRET_KEY=your_secret_key_min_50_chars

# Anthropic API (used by homelab-ops AI assistant)
ANTHROPIC_API_KEY=sk-ant-...

# Honeypot
HONEYPOT_IP=192.168.x.x
